# --- Sentry connection ---
SENTRY_BASE_URL=http://sentry.local:8000
SENTRY_API_TOKEN=replace-me
SENTRY_MOCK=false
SENTRY_INITIAL_BACKOFF_S=0.5

# --- Windcave HIT ---
WINDCAVE_BASE_URL=https://sec.windcave.com/pxmi3/pos.aspx
WINDCAVE_USER=AvidMax
WINDCAVE_KEY=replace-me
WINDCAVE_STATION=replace-with-terminal-serial
WINDCAVE_VENDOR_ID=Hightower
WINDCAVE_POS_NAME=AvidMaxPOS
WINDCAVE_DEVICE_ID=AvidMax-Reg1
WINDCAVE_POS_VERSION=1.0.0
WINDCAVE_CURRENCY=USD
WINDCAVE_TIMEZONE=US MST
WINDCAVE_MOCK=false
WINDCAVE_POLL_INTERVAL_MS=1000
WINDCAVE_MAX_POLL_DURATION_S=120
WINDCAVE_INITIAL_BACKOFF_S=0.5

# --- Tax (universal across all SKUs in v1) ---
TAX_RATE=0.0810
TAX_INCLUSIVE=false

# --- Pricing CSV import limits ---
PRICE_CSV_MAX_ROWS=5000

# --- Refund window ---
REFUND_WINDOW_DAYS=90

# --- Microsoft Fabric (Transaction Service REST API) ---
# The Fabric transaction service is one REST surface for everything the
# POS Service needs from Fabric: price catalog reads, sales-order writes
# (Phase C), customer lookups (Phase D). Empty URL puts the FabricClient
# in mock mode (the four-hour price sync becomes a no-op) so dev machines
# without Fabric credentials don't error at startup.
FABRIC_TRANSACTION_SERVICE_URL=
FABRIC_API_KEY=
FABRIC_REQUEST_TIMEOUT_S=30
# Price catalog poll interval in seconds. Default 14400 = 4 hours.
FABRIC_SYNC_INTERVAL_S=14400
# Fabric SO outbox drain loop. Defaults: poll every 5 seconds, claim
# up to 50 PENDING entries per pass.
FABRIC_OUTBOX_DRAIN_INTERVAL_S=5
FABRIC_OUTBOX_BATCH_SIZE=50

# --- Store info (for receipt header/footer) ---
STORE_NAME=AvidMax
STORE_ADDRESS_LINE_1=
STORE_ADDRESS_LINE_2=
STORE_PHONE=

# --- Auth ---
SESSION_SECRET_KEY=replace-with-random-32-bytes-base64
SESSION_TTL_HOURS=12

# --- Database ---
# Local dev: sqlite:///./pos.db (3 slashes = relative path)
# Docker deploy: sqlite:////data/pos.db (4 slashes = absolute path, persisted in the pos-data volume)
DATABASE_URL=sqlite:///./pos.db

# --- CORS / origins ---
ALLOWED_ORIGINS=http://pos-vm.local,http://localhost:5173

# --- Logging ---
LOG_LEVEL=INFO
DEBUG=false
