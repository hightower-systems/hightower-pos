# Listen address; localhost only by design.
LISTEN_HOST=127.0.0.1
LISTEN_PORT=9100

# The POS web app's URL. Requests with any other Origin are rejected
# with 403 forbidden_origin.
ALLOWED_ORIGIN=http://pos-vm.local:8080

# Printer USB identifiers. Defaults below are typical for a Star TSP100;
# verify on the actual hardware via Device Manager (Windows) or
# `system_profiler SPUSBDataType` (macOS) and set to whatever the
# printer reports.
PRINTER_VENDOR_ID=0x0519
PRINTER_PRODUCT_ID=0x0001
PRINTER_PROFILE=TSP100
PRINTER_PAPER_WIDTH=42

# Cash drawer wiring; daisy-chained off the printer. Pin 2 is the default
# for most models; some setups use Pin 5.
DRAWER_PIN=2
DRAWER_PULSE_ON_MS=120
DRAWER_PULSE_OFF_MS=240

PRINT_TEST_ON_STARTUP=true

# Show a system-tray icon on Windows. Set to false for headless / service
# installs that don't have a logged-in desktop session.
TRAY_ICON_ENABLED=true

LOG_LEVEL=INFO
